# Copy this file to .env and fill in your values.
#
# PostgreSQL (primary DB) — set this to use Postgres.
# If unset, the app falls back to SQLite (tasknet.db).
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Examples:
#   Local:    DATABASE_URL=postgresql://postgres:secret@localhost:5432/tasknet
#   Supabase: DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
#   Neon:     DATABASE_URL=postgresql://<user>:<password>@<host>/tasknet?sslmode=require
#
DATABASE_URL=
